# Secrets & env for the `eval` harness.
# Copy this file to `.env` in THIS folder (gitignored); the host loads it for the harness.
# A provider key in the repo-root .env already applies to every shape — only set one
# here to override it for eval specifically.

# Provider credential — which one you need depends on `agent.model` in your spec.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxx
# GEMINI_API_KEY=xxxxxxxx

# Plus any ${VAR} your spec references (tool configs, MCP servers, etc.).
