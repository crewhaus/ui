# Secrets & env for the `channel` bot harness.
# Copy this file to `.env` in THIS folder (gitignored); the host loads it for the daemon.

# Provider credential — which one you need depends on `agent.model` in your spec.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxx
# GEMINI_API_KEY=xxxxxxxx

# ── Channel tokens — set the ones your spec's channels.* block uses ──────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_APP_TOKEN=xapp-...
# DISCORD_BOT_TOKEN=...
# TELEGRAM_BOT_TOKEN=...
# WHATSAPP_TOKEN=...
# CREWHAUS_DEDUP_STORE=sqlite:./dedup.sqlite   # persist webhook de-dup across restarts
